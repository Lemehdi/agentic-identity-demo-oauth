# ═══════════════════════════════════════════════════════════════════════════════
#  Agentic Identity Demo — v2 — Environment Configuration
#  Copy this file to .env and fill in all values before running.
# ═══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
#  Idira — OIDC Token Provider
#  Where to find these values: Idira Admin Portal → Apps & Widgets
# ─────────────────────────────────────────────────────────────────────────────

# Your Idira tenant URL (no trailing slash)
idira_TENANT_URL=https://tenantID.id.cyberark.cloud

# The OAuth2 Application ID as configured in Idira
# Found in: Apps & Widgets → OAuth2 Client → General tab → "Application ID"
# This is used in the token endpoint URL: {TENANT}/oauth2/token/{APP_ID}
idira_APP_ID=your-idira-app-id

# OAuth2 client credentials for the application
# Create a service account and check the box "Is Oauth Confidential CLient"
idira_CLIENT_ID=your-client-id
idira_CLIENT_SECRET=your-client-secret

# OAuth2 scope — must include "openid" to receive an id_token (JWT)
# Add any custom scopes your idira app defines, space-separated
idira_SCOPE=openid


# ─────────────────────────────────────────────────────────────────────────────
#  ANTHROPIC — Workload Identity Federation
#  Where to find these values: Claude Console → Settings
# ─────────────────────────────────────────────────────────────────────────────

# Your Anthropic Organization UUID
# Found in: Console → Settings → Organization → Organization ID
ANTHROPIC_ORGANIZATION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Service account ID (created in Console → Settings → Service accounts)
# Format: svac_xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_SERVICE_ACCOUNT_ID=svac_xxxxxxxxxxxxxxxxxxxx

# Federation rule ID (created in Console → Settings → Workload identity → Federation rules)
# Format: fdrl_xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_FEDERATION_RULE_ID=fdrl_xxxxxxxxxxxxxxxxxxxx

# Workspace ID (the workspace the service account is a member of)
# Found in: Console → Settings → Workload identity → Federation rules → rule details
# Format: wrkspc_xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_WORKSPACE_ID=wrkspc_xxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────────────────
#  NOTE: Do NOT set ANTHROPIC_API_KEY
#  This demo uses WIF — a static API key is not needed and will print a warning
#  if detected (it does not affect functionality, but is misleading).
# ─────────────────────────────────────────────────────────────────────────────
